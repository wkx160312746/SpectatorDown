PORT=8787
HOST=0.0.0.0
NODE_ENV=production

ACCESS_KEY=replace-with-a-strong-access-key
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true
SESSION_TTL_SECONDS=43200

